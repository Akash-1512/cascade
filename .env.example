# ---------------------------------------------------------------------------
# cascade — environment variables
# Copy this file to .env and fill in the values. Never commit .env.
# ---------------------------------------------------------------------------

# --- Application -----------------------------------------------------------
CASCADE_ENV=development                # development | staging | production
LOG_LEVEL=INFO                         # DEBUG | INFO | WARNING | ERROR
SECRET_KEY=change-me-to-a-random-32-byte-hex-string
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- Storage ---------------------------------------------------------------
DATABASE_URL=postgresql+psycopg://cascade:cascade@localhost:5432/cascade
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_COLLECTION=cascade_memory

# --- LLM provider ----------------------------------------------------------
# Primary — Groq (free tier, LLaMA 3.3 70B)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Fallback — Together AI (optional)
TOGETHER_API_KEY=
TOGETHER_MODEL=meta-llama/Llama-3.3-70B-Instruct-Turbo

# --- Embeddings ------------------------------------------------------------
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# --- Observability ---------------------------------------------------------
# LangSmith — agent traces
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=cascade

# Langfuse — LLM cost & latency
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# MLflow — eval runs & prompt registry
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT=cascade-evals

# --- MCP server ------------------------------------------------------------
MCP_HOST=0.0.0.0
MCP_PORT=8765
MCP_AUTH_REQUIRED=true

# --- Eval gate thresholds (override defaults from eval_data/thresholds.yaml) ---
# EVAL_DRAFTING_F1_MIN=0.85
# EVAL_RETRIEVAL_FAITHFULNESS_MIN=0.90
# EVAL_REDTEAM_PASS_RATE_MIN=0.95
